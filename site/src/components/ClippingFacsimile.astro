---
/**
 * The facsimile pane for a Papers Past CLIPPING: a single newspaper article that
 * the source archive slices into several scan STRIPS. They stack in reading
 * order (`f001…fNNN` -- headline → sub-head → body → …), reconstructing the
 * clipping as it was printed. Each strip is a small raster GIF (from our CDN),
 * so this is a plain, honest stack of `<img>` on the archival ground -- NO
 * deep-zoom/OpenSeadragon (that is for the tall single-page facsimiles).
 *
 * The scan stays the authority beside the (noisy) OCR reading; the strips carry
 * no oxide -- a facsimile is not a critical mark.
 */
import type { ImageDescriptor } from '@/browser/model';

interface Props {
  /** The ordered strips (f001…fNNN), stacked top-to-bottom. */
  strips: ImageDescriptor[];
  /** Human label for the clipping (announced to assistive tech). */
  label: string;
}
const { strips, label } = Astro.props;
---

<figure class="clipping" aria-label={label}>
  {strips.map((strip, index) => (
    <img
      class="clipping__strip"
      src={strip.url}
      alt={`${label} — strip ${index + 1} of ${strips.length}`}
      loading={index === 0 ? 'eager' : 'lazy'}
      decoding="async"
    />
  ))}
</figure>

<style>
  /* The archival ground the strips sit on -- the same mat-board as the deep-zoom
     facsimile, so a clipping reads as the same kind of object. Natural height
     (a clipping is short); the reading view lets it scroll with the page. */
  .clipping {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: 22px;
    background: #d9d7ce;
    border-right: 1px solid var(--rule);
  }

  /* Each strip is a scanned artifact: a white matte, a hairline frame, and a
     quiet lift -- so the stacked regions read as pieces of one clipping, not a
     seamless image. Widths differ; cap to the pane and never upscale. */
  .clipping__strip {
    display: block;
    max-width: 100%;
    height: auto;
    background: #fff;
    padding: 3px;
    border: 1px solid var(--rule);
    box-shadow: 0 1px 3px -1px rgba(23, 21, 15, 0.4);
  }

  @media (max-width: 820px) {
    .clipping {
      border-right: 0;
      border-bottom: 1px solid var(--rule);
    }
  }
</style>
