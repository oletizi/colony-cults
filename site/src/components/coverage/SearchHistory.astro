---
/**
 * T008 -- the search-history section of `/coverage`. The audit record of where
 * the archive has already looked: a monospace repository x campaign matrix in
 * the "Prospectus / Dossier" hand, one row per search, followed by a quiet
 * by-repository rollup line.
 *
 * The signature mark: each open question is a leading oxide `›` tick -- the
 * archive's critical hand on a question still unanswered. Everything held or
 * settled stays quiet in `--ink`/`--slate`/`--faint`; a cell with nothing open
 * reads "— none open" in `--faint`. There is deliberately NEVER a percentage,
 * ratio, or progress bar here (design non-negotiable) -- coverage is a record
 * of searches, never a score.
 *
 * The matrix is wrapped in an `overflow-x:auto` rail so it scrolls inside its
 * own container on narrow screens rather than forcing the page body sideways.
 */
import type { CoverageSearchHistory } from '@/bibliography/coverage/coverage-model';

interface Props {
  history: CoverageSearchHistory;
}

const { history } = Astro.props;
const { matrix, byRepository } = history;

const countLabel = `${matrix.length} ${matrix.length === 1 ? 'search' : 'searches'}`;
---

<section class="sec">
  <p class="sec__label">Search history<span class="sec__count">{countLabel}</span></p>
  {matrix.length === 0 ? (
    <p class="empty">No searches logged yet.</p>
  ) : (
    <>
      <div class="hist__scroll">
        <table class="hist">
          <thead>
            <tr>
              <th>Repository</th>
              <th>Scope</th>
              <th>Last searched</th>
              <th>Open questions</th>
            </tr>
          </thead>
          <tbody>
            {matrix.map((cell) => (
              <tr>
                <td class="hist__repo">{cell.repository}</td>
                <td>{cell.scope}</td>
                <td>{cell.lastSearched}</td>
                <td>
                  {cell.openQuestions.length === 0 ? (
                    <span class="hist__none">— none open</span>
                  ) : (
                    cell.openQuestions.map((question) => (
                      <span class="hist__q">{question}</span>
                    ))
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {byRepository.length > 0 ? (
        <p class="rollup">
          By repository
          {byRepository.map((repo) => (
            <>
              <span class="rollup__sep">·</span>{repo.repository} last {repo.lastSearched}
            </>
          ))}
        </p>
      ) : null}
    </>
  )}
</section>

<style>
  .sec {
    margin-top: 56px;
  }

  .sec__label {
    display: flex;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--faint);
    margin: 0 0 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--rule);
  }

  .sec__count {
    margin-left: auto;
    color: var(--faint);
  }

  .empty {
    font-family: var(--grote);
    font-size: 14px;
    color: var(--faint);
    font-style: italic;
    margin: 0;
  }

  /* The matrix scrolls inside its own rail on narrow screens; the page body
     never scrolls sideways (design quality floor). */
  .hist__scroll {
    overflow-x: auto;
  }

  /* The audit matrix: one row per search, monospace throughout so it reads as
     a record rather than a table of results. */
  .hist {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--mono);
    font-size: 12px;
  }

  .hist th {
    text-align: left;
    font-weight: inherit;
    color: var(--faint);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0 16px 10px 0;
    border-bottom: 1px solid var(--rule);
    white-space: nowrap;
  }

  .hist td {
    padding: 12px 16px 12px 0;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
    color: var(--slate);
  }

  .hist__repo {
    color: var(--ink);
  }

  /* The stamped gap: an open question carries the archive's oxide `›` tick --
     a mark on evidence still missing. */
  .hist__q {
    display: block;
    color: var(--ink);
  }

  .hist__q::before {
    content: "›";
    color: var(--oxide);
    margin-right: 7px;
  }

  .hist__none {
    color: var(--faint);
  }

  .rollup {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
    margin: 16px 0 0;
    overflow-wrap: anywhere;
  }

  .rollup__sep {
    color: var(--rule);
    margin: 0 7px;
  }
</style>
