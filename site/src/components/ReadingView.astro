---
/**
 * The reading view -- layout ① "Facsimile & parallel text". The deep-zoom scan
 * LEADS (left, ~56%); beside it the text column is ordered by usefulness to an
 * English-speaking reader: the ENGLISH TRANSLATION reads first and prominent,
 * and the two warm French readings (corrected + raw OCR) are FOLDED beneath it
 * (SourcePane's native <details>). The breadcrumb chrome bar STICKS to the top
 * of the viewport and carries a page-nav, so within-issue forward/back never
 * needs a scroll; a fuller page-nav + provenance line repeats in the footer.
 *
 * Every datum shown is required by the loader (fail-loud); this component
 * substitutes nothing. The full monospace provenance-rail signature and the
 * embedded display face are US4 -- this is the structural reading view.
 */
import type { PageView, SourceKind, SourceLanguage } from '@/browser/model';
import FacsimileViewer from './FacsimileViewer.astro';
import SourcePane from './SourcePane.astro';
import TranslationPane from './TranslationPane.astro';
import PageNav from './PageNav.astro';
import ProvenanceRail from './ProvenanceRail.astro';
import Masthead from './Masthead.astro';

interface Props {
  sourceId: string;
  sourceTitle: string;
  /** Whether this source is a periodical (issue-framed) or a monograph (book-framed). */
  kind: SourceKind;
  /**
   * The source language. `'French'` shows the machine English translation
   * leading, with the French source readings folded beneath. `'English'` is a
   * single-language source: its own English text reads beside the scan and there
   * is no French source pane.
   */
  language: SourceLanguage;
  issueDate: string;
  page: PageView;
  /** 1-based position of this page within its issue. */
  positionInIssue: number;
  pageCount: number;
  prevHref: string | null;
  nextHref: string | null;
  /** Link to the source overview (`/sources/{sourceId}/`). */
  sourceHref: string;
  /** Link to this issue's first page -- "jump to issue start"; null if unknown. */
  issueFirstPageHref: string | null;
}
const {
  sourceId,
  sourceTitle,
  kind,
  language,
  issueDate,
  page,
  positionInIssue,
  pageCount,
  prevHref,
  nextHref,
  sourceHref,
  issueFirstPageHref,
} = Astro.props;

const isBook = kind === 'monograph';
// An English-language source has no French source layer: its own English text
// reads beside the scan, with no folded French readings.
const isEnglishSource = language === 'English';
const pageLabel = `p.${positionInIssue}`;
// A book page is placed within the whole volume ("p. N / 32"); a periodical page
// is placed within its dated issue. Frame every label the same way.
const contextLabel = isBook ? `p. ${positionInIssue} / ${pageCount}` : `${issueDate} · ${pageLabel}`;
const facsimileLabel = isBook
  ? `${sourceTitle}, p. ${positionInIssue} / ${pageCount} — scanned page ${page.folioId}`
  : `${sourceTitle}, ${issueDate}, ${pageLabel} — scanned page ${page.folioId}`;
// The catalogue line used as the Pagefind result title (US3 / T022): matches the
// document <title> exactly. Passed via a data-attribute (not the `title:literal`
// meta form) so a colon in the source title cannot corrupt the meta value.
const searchTitle = isBook
  ? `${sourceTitle} · p. ${positionInIssue} / ${pageCount}`
  : `${sourceTitle} · ${issueDate} · ${pageLabel}`;
const pagenavLabel = isBook ? 'Navigation dans le livre' : 'Navigation dans le numéro';
const provenanceLabel = isBook
  ? `Provenance — p. ${positionInIssue} / ${pageCount}`
  : `Provenance — ${issueDate}, ${pageLabel}`;
---

<article class="reading" aria-label={`Reading view — ${sourceTitle}, ${contextLabel}`}>
  <header class="reading__masthead">
    <Masthead tail={sourceId} gap={10} />
    <h1 class="reading__title">{sourceTitle}</h1>
    <p class="reading__issue">{contextLabel}</p>
  </header>

  <div class="reading__frame">
    <div class="reading__chrome">
      {isBook ? (
        <span class="reading__crumb">
          <a class="reading__crumb-link" href={sourceHref}><b>{sourceTitle}</b></a>
          <span class="reading__sep">›</span>
          <b>p. {positionInIssue} / {pageCount}</b>
        </span>
      ) : (
        <span class="reading__crumb">
          <a class="reading__crumb-link" href={sourceHref}><b>{sourceId}</b></a>
          <span class="reading__sep">›</span>
          {issueFirstPageHref ? (
            <a class="reading__crumb-link" href={issueFirstPageHref}>{issueDate}</a>
          ) : (
            issueDate
          )}
          <span class="reading__sep">›</span>
          <b>{pageLabel}</b>
        </span>
      )}
      <span class="reading__spacer"></span>
      <PageNav
        positionInIssue={positionInIssue}
        pageCount={pageCount}
        prevHref={prevHref}
        nextHref={nextHref}
        compact
      />
    </div>

    <div class="reading__body">
      <div class="reading__facsimile">
        <FacsimileViewer image={page.image} label={facsimileLabel} />
      </div>
      <div
        class="reading__text"
        data-pagefind-body
        data-pagefind-meta="title[data-title]"
        data-title={searchTitle}
      >
        {isEnglishSource ? (
          <TranslationPane english={page.english} role="source" />
        ) : (
          <>
            <TranslationPane english={page.english} />
            <SourcePane
              ocrFrench={page.ocrFrench}
              correctedFrench={page.correctedFrench}
              ocrCondition={page.ocrCondition}
            />
          </>
        )}
      </div>
    </div>

    <nav class="reading__pagenav" aria-label={pagenavLabel}>
      <PageNav
        positionInIssue={positionInIssue}
        pageCount={pageCount}
        prevHref={prevHref}
        nextHref={nextHref}
      />
      <span class="reading__spacer"></span>
      <span class="reading__foot-mark">Provenance below</span>
    </nav>

    <ProvenanceRail provenance={page.provenance} label={provenanceLabel} />
  </div>
</article>

<style>
  .reading {
    max-width: 1180px;
    margin: 0 auto;
    padding: 48px 28px 96px;
  }

  .reading__masthead {
    margin-bottom: 26px;
  }

  .reading__title {
    font-family: var(--didone);
    font-weight: 400;
    font-size: clamp(28px, 5vw, 46px);
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0 0 8px;
  }

  .reading__issue {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.05em;
    color: var(--faint);
    margin: 0;
  }

  .reading__frame {
    border: 1px solid var(--rule);
    background: #fff;
    box-shadow: 0 1px 0 var(--rule), 0 22px 44px -30px rgba(23, 21, 15, 0.45);
  }

  .reading__chrome {
    position: sticky;
    top: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 11px 16px;
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    box-shadow: 0 6px 14px -12px rgba(23, 21, 15, 0.55);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
    letter-spacing: 0.05em;
  }

  .reading__crumb b {
    color: var(--ink);
    font-weight: 600;
  }

  .reading__crumb-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }

  .reading__crumb-link:hover {
    color: var(--oxide);
    border-bottom-color: var(--oxide);
  }

  .reading__crumb-link:hover b {
    color: var(--oxide);
  }

  .reading__sep {
    color: var(--rule);
    margin: 0 2px;
  }

  .reading__spacer {
    flex: 1;
  }

  .reading__body {
    display: grid;
    grid-template-columns: 1.25fr 0.95fr;
  }

  .reading__facsimile {
    min-width: 0;
    /* Keep the authoritative scan pinned while the (leading) English
       translation and folded French readings scroll past it. `align-self`
       stops the grid cell from stretching to the text column's height, which
       would leave no travel for the sticky pin. `top` clears the sticky
       chrome bar above. The height handed to FacsimileViewer fills the
       viewport below that offset so the mount always has a definite height. */
    position: sticky;
    top: 44px;
    align-self: start;
    --facsimile-height: min(calc(100vh - 68px), 860px);
  }

  .reading__text {
    min-width: 0;
  }

  .reading__pagenav {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 16px;
    border-top: 1px solid var(--rule);
    background: var(--paper);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
  }

  /* A quiet apparatus cue pointing at the provenance stamp below -- no oxide;
     the rail's rights mark is the only critical red in the footer. */
  .reading__foot-mark {
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--faint);
  }

  @media (max-width: 820px) {
    .reading__body {
      grid-template-columns: 1fr;
    }

    .reading__facsimile {
      position: static;
      --facsimile-height: min(68vh, 460px);
    }

    .reading__pagenav {
      flex-wrap: wrap;
    }
  }
</style>
