---
/**
 * The reading view -- layout ① "Facsimile & parallel text". The deep-zoom scan
 * LEADS (left, ~56%); beside it the text column is ordered by usefulness to an
 * English-speaking reader: the ENGLISH TRANSLATION reads first and prominent,
 * and the two warm French readings (corrected + raw OCR) are FOLDED beneath it
 * (SourcePane's native <details>). The breadcrumb chrome bar STICKS to the top
 * of the viewport and carries a page-nav, so within-issue forward/back never
 * needs a scroll; a fuller page-nav + provenance line repeats in the footer.
 *
 * Every datum shown is required by the loader (fail-loud); this component
 * substitutes nothing. The full monospace provenance-rail signature and the
 * embedded display face are US4 -- this is the structural reading view.
 */
import type { PageView } from '@/browser/model';
import FacsimileViewer from './FacsimileViewer.astro';
import SourcePane from './SourcePane.astro';
import TranslationPane from './TranslationPane.astro';
import PageNav from './PageNav.astro';

interface Props {
  sourceId: string;
  sourceTitle: string;
  issueId: string;
  issueDate: string;
  page: PageView;
  /** 1-based position of this page within its issue. */
  positionInIssue: number;
  pageCount: number;
  prevHref: string | null;
  nextHref: string | null;
  /** Link to the source overview (`/sources/{sourceId}/`). */
  sourceHref: string;
  /** Link to this issue's first page -- "jump to issue start"; null if unknown. */
  issueFirstPageHref: string | null;
}
const {
  sourceId,
  sourceTitle,
  issueId,
  issueDate,
  page,
  positionInIssue,
  pageCount,
  prevHref,
  nextHref,
  sourceHref,
  issueFirstPageHref,
} = Astro.props;

const pageLabel = `p.${positionInIssue}`;
const facsimileLabel = `${sourceTitle}, ${issueDate}, ${pageLabel} — scanned page ${page.folioId}`;
// The catalogue line used as the Pagefind result title (US3 / T022): matches the
// document <title> exactly. Passed via a data-attribute (not the `title:literal`
// meta form) so a colon in the source title cannot corrupt the meta value.
const searchTitle = `${sourceTitle} · ${issueDate} · ${pageLabel}`;
const prov = page.provenance;
const shaShort = prov.sha256.slice(0, 12);
---

<article class="reading" aria-label={`Reading view — ${sourceTitle}, ${issueDate}, ${pageLabel}`}>
  <header class="reading__masthead">
    <p class="reading__eyebrow">Corpus&nbsp;· {sourceId}</p>
    <h1 class="reading__title">{sourceTitle}</h1>
    <p class="reading__issue">{issueDate}&nbsp;· {pageLabel}</p>
  </header>

  <div class="reading__frame">
    <div class="reading__chrome">
      <span class="reading__crumb">
        <a class="reading__crumb-link" href={sourceHref}><b>{sourceId}</b></a>
        <span class="reading__sep">›</span>
        {issueFirstPageHref ? (
          <a class="reading__crumb-link" href={issueFirstPageHref}>{issueDate}</a>
        ) : (
          issueDate
        )}
        <span class="reading__sep">›</span>
        <b>{pageLabel}</b>
      </span>
      <span class="reading__spacer"></span>
      <PageNav
        positionInIssue={positionInIssue}
        pageCount={pageCount}
        prevHref={prevHref}
        nextHref={nextHref}
        compact
      />
    </div>

    <div class="reading__body">
      <div class="reading__facsimile">
        <FacsimileViewer image={page.image} label={facsimileLabel} />
      </div>
      <div
        class="reading__text"
        data-pagefind-body
        data-pagefind-meta="title[data-title]"
        data-title={searchTitle}
      >
        <TranslationPane english={page.english} />
        <SourcePane
          ocrFrench={page.ocrFrench}
          correctedFrench={page.correctedFrench}
          ocrCondition={page.ocrCondition}
        />
      </div>
    </div>

    <nav class="reading__pagenav" aria-label="Navigation dans le numéro">
      <PageNav
        positionInIssue={positionInIssue}
        pageCount={pageCount}
        prevHref={prevHref}
        nextHref={nextHref}
      />
      <span class="reading__spacer"></span>
      <span class="reading__provenance" title={`sha256:${prov.sha256}`}>
        <span class="reading__prov-issue">{issueId}</span>
        <span class="reading__sep">·</span>
        {prov.ark}
        <span class="reading__sep">·</span>
        <span class="reading__rights">{prov.rights}</span>
        <span class="reading__sep">·</span>
        sha256:{shaShort}…
      </span>
    </nav>
  </div>
</article>

<style>
  .reading {
    max-width: 1180px;
    margin: 0 auto;
    padding: 48px 28px 96px;
  }

  .reading__masthead {
    margin-bottom: 26px;
  }

  .reading__eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--oxide);
    margin: 0 0 10px;
  }

  .reading__title {
    font-family: var(--didone);
    font-weight: 400;
    font-size: clamp(28px, 5vw, 46px);
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0 0 8px;
  }

  .reading__issue {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.05em;
    color: var(--faint);
    margin: 0;
  }

  .reading__frame {
    border: 1px solid var(--rule);
    background: #fff;
    box-shadow: 0 1px 0 var(--rule), 0 22px 44px -30px rgba(23, 21, 15, 0.45);
  }

  .reading__chrome {
    position: sticky;
    top: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 11px 16px;
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    box-shadow: 0 6px 14px -12px rgba(23, 21, 15, 0.55);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
    letter-spacing: 0.05em;
  }

  .reading__crumb b {
    color: var(--ink);
    font-weight: 600;
  }

  .reading__crumb-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }

  .reading__crumb-link:hover {
    color: var(--oxide);
    border-bottom-color: var(--oxide);
  }

  .reading__crumb-link:hover b {
    color: var(--oxide);
  }

  .reading__sep {
    color: var(--rule);
    margin: 0 2px;
  }

  .reading__spacer {
    flex: 1;
  }

  .reading__body {
    display: grid;
    grid-template-columns: 1.25fr 0.95fr;
  }

  .reading__facsimile {
    min-width: 0;
    /* Keep the authoritative scan pinned while the (leading) English
       translation and folded French readings scroll past it. `align-self`
       stops the grid cell from stretching to the text column's height, which
       would leave no travel for the sticky pin. `top` clears the sticky
       chrome bar above. The height handed to FacsimileViewer fills the
       viewport below that offset so the mount always has a definite height. */
    position: sticky;
    top: 44px;
    align-self: start;
    --facsimile-height: min(calc(100vh - 68px), 860px);
  }

  .reading__text {
    min-width: 0;
  }

  .reading__pagenav {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 16px;
    border-top: 1px solid var(--rule);
    background: var(--paper);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
  }

  .reading__provenance {
    letter-spacing: 0.04em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .reading__rights {
    color: var(--oxide);
  }

  @media (max-width: 820px) {
    .reading__body {
      grid-template-columns: 1fr;
    }

    .reading__facsimile {
      position: static;
      --facsimile-height: min(68vh, 460px);
    }

    .reading__pagenav {
      flex-wrap: wrap;
    }

    .reading__provenance {
      white-space: normal;
      flex-basis: 100%;
    }
  }
</style>
