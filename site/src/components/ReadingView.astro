---
/**
 * The reading view -- layout ① "Facsimile & parallel text". The deep-zoom scan
 * LEADS (left, ~56%); the raw French OCR and the English translation are STACKED
 * beside it (the propaganda's warm voice over the critical frame's cool one).
 * A breadcrumb chrome bar sits above; a page-nav + compact provenance line sits
 * below (within-issue prev/next -- the fuller source/issue navigation is US2).
 *
 * Every datum shown is required by the loader (fail-loud); this component
 * substitutes nothing. The full monospace provenance-rail signature and the
 * embedded display face are US4 -- this is the structural reading view.
 */
import type { PageView } from '@/browser/model';
import FacsimileViewer from './FacsimileViewer.astro';
import SourcePane from './SourcePane.astro';
import TranslationPane from './TranslationPane.astro';

interface Props {
  sourceId: string;
  sourceTitle: string;
  issueId: string;
  issueDate: string;
  page: PageView;
  /** 1-based position of this page within its issue. */
  positionInIssue: number;
  pageCount: number;
  prevHref: string | null;
  nextHref: string | null;
}
const {
  sourceId,
  sourceTitle,
  issueId,
  issueDate,
  page,
  positionInIssue,
  pageCount,
  prevHref,
  nextHref,
} = Astro.props;

const pageLabel = `p.${positionInIssue}`;
const facsimileLabel = `${sourceTitle}, ${issueDate}, ${pageLabel} — scanned page ${page.folioId}`;
const prov = page.provenance;
const shaShort = prov.sha256.slice(0, 12);
---

<article class="reading" aria-label={`Reading view — ${sourceTitle}, ${issueDate}, ${pageLabel}`}>
  <header class="reading__masthead">
    <p class="reading__eyebrow">Corpus&nbsp;· {sourceId}</p>
    <h1 class="reading__title">{sourceTitle}</h1>
    <p class="reading__issue">{issueDate}&nbsp;· {pageLabel}</p>
  </header>

  <div class="reading__frame">
    <div class="reading__chrome">
      <span class="reading__crumb">
        <b>{sourceId}</b>
        <span class="reading__sep">›</span>
        {issueDate}
        <span class="reading__sep">›</span>
        <b>{pageLabel}</b>
      </span>
      <span class="reading__spacer"></span>
      <span class="reading__pill reading__pill--on">FR + EN</span>
    </div>

    <div class="reading__body">
      <div class="reading__facsimile">
        <FacsimileViewer image={page.image} label={facsimileLabel} />
      </div>
      <div class="reading__text">
        <SourcePane
          ocrFrench={page.ocrFrench}
          correctedFrench={page.correctedFrench}
          ocrCondition={page.ocrCondition}
        />
        <TranslationPane english={page.english} />
      </div>
    </div>

    <nav class="reading__pagenav" aria-label="Navigation dans le numéro">
      {prevHref ? (
        <a class="reading__arrow" href={prevHref} rel="prev" aria-label="Page précédente">‹</a>
      ) : (
        <span class="reading__arrow reading__arrow--off" aria-hidden="true">‹</span>
      )}
      <span class="reading__count">page {positionInIssue} / {pageCount}</span>
      {nextHref ? (
        <a class="reading__arrow" href={nextHref} rel="next" aria-label="Page suivante">›</a>
      ) : (
        <span class="reading__arrow reading__arrow--off" aria-hidden="true">›</span>
      )}
      <span class="reading__spacer"></span>
      <span class="reading__provenance" title={`sha256:${prov.sha256}`}>
        <span class="reading__prov-issue">{issueId}</span>
        <span class="reading__sep">·</span>
        {prov.ark}
        <span class="reading__sep">·</span>
        <span class="reading__rights">{prov.rights}</span>
        <span class="reading__sep">·</span>
        sha256:{shaShort}…
      </span>
    </nav>
  </div>
</article>

<style>
  .reading {
    max-width: 1180px;
    margin: 0 auto;
    padding: 48px 28px 96px;
  }

  .reading__masthead {
    margin-bottom: 26px;
  }

  .reading__eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--oxide);
    margin: 0 0 10px;
  }

  .reading__title {
    font-family: var(--didone);
    font-weight: 400;
    font-size: clamp(28px, 5vw, 46px);
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0 0 8px;
  }

  .reading__issue {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.05em;
    color: var(--faint);
    margin: 0;
  }

  .reading__frame {
    border: 1px solid var(--rule);
    background: #fff;
    box-shadow: 0 1px 0 var(--rule), 0 22px 44px -30px rgba(23, 21, 15, 0.45);
  }

  .reading__chrome {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
    letter-spacing: 0.05em;
  }

  .reading__crumb b {
    color: var(--ink);
    font-weight: 600;
  }

  .reading__sep {
    color: var(--rule);
    margin: 0 2px;
  }

  .reading__spacer {
    flex: 1;
  }

  .reading__pill {
    border: 1px solid var(--rule);
    padding: 3px 8px;
    border-radius: 2px;
    color: var(--slate);
  }

  .reading__pill--on {
    background: var(--slate);
    color: #fff;
    border-color: var(--slate);
  }

  .reading__body {
    display: grid;
    grid-template-columns: 1.25fr 0.95fr;
  }

  .reading__facsimile {
    min-width: 0;
  }

  .reading__text {
    min-width: 0;
  }

  .reading__pagenav {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-top: 1px solid var(--rule);
    background: var(--paper);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
  }

  .reading__arrow {
    width: 24px;
    height: 24px;
    display: grid;
    place-items: center;
    border: 1px solid var(--rule);
    color: var(--slate);
    text-decoration: none;
  }

  .reading__arrow:hover {
    border-color: var(--oxide);
    color: var(--oxide);
  }

  .reading__arrow--off {
    color: var(--rule);
    cursor: default;
  }

  .reading__provenance {
    letter-spacing: 0.04em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .reading__rights {
    color: var(--oxide);
  }

  @media (max-width: 820px) {
    .reading__body {
      grid-template-columns: 1fr;
    }

    .reading__pagenav {
      flex-wrap: wrap;
    }

    .reading__provenance {
      white-space: normal;
      flex-basis: 100%;
    }
  }
</style>
