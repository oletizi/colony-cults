---
/**
 * The leading deep-zoom facsimile pane of the reading view (layout ①). It is a
 * mount point for the T016 OpenSeadragon island: the resolved, provider-
 * agnostic {@link ImageDescriptor} is serialized onto the mount's data
 * attribute, and the island (imported by the `<script>` below) reads it and
 * initializes pan/zoom. The scan LEADS -- our OCR is noisy, so the authoritative
 * image stays prominent.
 *
 * OSD's own sprite chrome is disabled (CSP-safe); this component supplies the
 * zoom-in / zoom-out / reset controls the island wires to the viewport.
 */
import type { ImageDescriptor } from '@/browser/model';

interface Props {
  image: ImageDescriptor;
  /** Human label for the scanned page (announced to assistive tech). */
  label: string;
}
const { image, label } = Astro.props;
const descriptorJson = JSON.stringify(image);
---

<figure class="facsimile" data-osd-root>
  <div
    class="facsimile__stage"
    data-osd-mount
    data-osd-descriptor={descriptorJson}
    role="img"
    aria-label={label}
  >
  </div>
  <figcaption class="facsimile__controls" aria-hidden="false">
    <button type="button" class="facsimile__btn" data-osd-zoom-in aria-label="Agrandir">+</button>
    <button type="button" class="facsimile__btn" data-osd-zoom-out aria-label="Réduire">&minus;</button>
    <button type="button" class="facsimile__btn facsimile__btn--reset" data-osd-reset aria-label="Réinitialiser le cadrage">&#8634;</button>
  </figcaption>
  <noscript>
    <p class="facsimile__noscript">
      La visionneuse haute résolution nécessite JavaScript. Image source : {image.url}
    </p>
  </noscript>
</figure>

<script>
  import { mountAll } from '../islands/viewer';
  mountAll();
</script>

<style>
  .facsimile {
    position: relative;
    margin: 0;
    min-height: 560px;
    background: #d9d7ce;
    border-right: 1px solid var(--rule);
  }

  .facsimile__stage {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* OpenSeadragon injects an absolutely-positioned canvas container; keep it
     clipped to the stage. */
  .facsimile__stage :global(.openseadragon-canvas) {
    outline: none;
  }

  .facsimile__controls {
    position: absolute;
    left: 12px;
    bottom: 12px;
    display: flex;
    gap: 1px;
    margin: 0;
    z-index: 2;
  }

  .facsimile__btn {
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    padding: 0;
    border: 0;
    font-family: var(--mono);
    font-size: 15px;
    line-height: 1;
    color: #fff;
    background: rgba(23, 21, 15, 0.72);
    cursor: pointer;
  }

  .facsimile__btn:hover {
    background: var(--oxide);
  }

  .facsimile__btn--reset {
    font-size: 13px;
  }

  .facsimile__noscript {
    position: absolute;
    inset: auto 12px 52px 12px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--slate);
    word-break: break-all;
  }

  @media (max-width: 820px) {
    .facsimile {
      min-height: 340px;
      border-right: 0;
      border-bottom: 1px solid var(--rule);
    }
  }
</style>
