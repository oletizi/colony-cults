---
/**
 * The English reading pane -- the critical frame's voice, set cool (slate
 * ground, grotesque / mono). For an English-speaking reader this is the PRIMARY
 * text of the page, so it LEADS the text column next to the scan.
 *
 * Two roles (single-language sources, spec: english-sources):
 *  - `translation` (default): a French source's machine English TRANSLATION.
 *    Labelled "Translation · English" and stamped machine-assisted / not
 *    human-reviewed, so the apparatus never lets the machine reading pass for an
 *    authoritative one. The warm French source readings fold beneath it.
 *  - `source`: an ENGLISH-language source's own text (transcribed from the
 *    scan) -- it is NOT a translation, so it is labelled simply "English" and
 *    carries no machine-translation stamp; the scan beside it is the authority.
 *
 * Line breaks are preserved.
 */
interface Props {
  english: string;
  /** `translation` = a machine English translation; `source` = the source's own English text. */
  role?: 'translation' | 'source';
}
const { english, role = 'translation' } = Astro.props;
const text = english.trim();
const hasText = text.length > 0;
const isSource = role === 'source';
const ariaLabel = isSource ? 'English text' : 'Translation into English';
const emptyMessage = isSource
  ? 'No transcribed text for this page.'
  : 'No English translation is available for this page.';
---

<section class="translation" aria-label={ariaLabel}>
  <p class="translation__label" data-pagefind-ignore>
    <span class="translation__lede-mark">Reading</span>
    {isSource ? 'English' : <>Translation&nbsp;· English</>}
  </p>
  {hasText ? (
    <div class="translation__body">{text}</div>
  ) : (
    <p class="translation__empty">{emptyMessage}</p>
  )}
  {isSource ? null : (
    <p class="translation__stamp" data-pagefind-ignore>machine-assisted · not human-reviewed</p>
  )}
</section>

<style>
  .translation {
    background: var(--slate);
    color: #edeff1;
    padding: 28px 30px 26px;
  }

  .translation__label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9fb0bc;
    margin: 0 0 16px;
  }

  /* Names this pane the primary reading -- the one text the reader is here for. */
  .translation__lede-mark {
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--slate);
    background: #cdd6dc;
    padding: 3px 7px;
    border-radius: 2px;
  }

  .translation__body {
    font-family: var(--grote);
    font-size: 16px;
    line-height: 1.7;
    color: #eef2f4;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .translation__empty {
    font-family: var(--grote);
    font-size: 13px;
    font-style: italic;
    color: #9fb0bc;
    margin: 0;
  }

  .translation__stamp {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: #8ea1ad;
    margin: 16px 0 0;
  }
</style>
