---
/**
 * The translation pane -- the critical frame's voice, set cool (slate ground,
 * grotesque / mono). For an English-speaking reader this is the PRIMARY text of
 * the page, so it LEADS the text column next to the scan (the warm French
 * readings are folded beneath it). It is explicitly marked as machine-assisted
 * and not human-reviewed, so the apparatus never lets the machine reading pass
 * for an authoritative one. Line breaks are preserved.
 */
interface Props {
  english: string;
}
const { english } = Astro.props;
const text = english.trim();
const hasText = text.length > 0;
---

<section class="translation" aria-label="Translation into English">
  <p class="translation__label">
    <span class="translation__lede-mark">Reading</span>
    Translation&nbsp;· English
  </p>
  {hasText ? (
    <div class="translation__body">{text}</div>
  ) : (
    <p class="translation__empty">No English translation is available for this page.</p>
  )}
  <p class="translation__stamp">machine-assisted · not human-reviewed</p>
</section>

<style>
  .translation {
    background: var(--slate);
    color: #edeff1;
    padding: 28px 30px 26px;
  }

  .translation__label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9fb0bc;
    margin: 0 0 16px;
  }

  /* Names this pane the primary reading -- the one text the reader is here for. */
  .translation__lede-mark {
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--slate);
    background: #cdd6dc;
    padding: 3px 7px;
    border-radius: 2px;
  }

  .translation__body {
    font-family: var(--grote);
    font-size: 16px;
    line-height: 1.7;
    color: #eef2f4;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .translation__empty {
    font-family: var(--grote);
    font-size: 13px;
    font-style: italic;
    color: #9fb0bc;
    margin: 0;
  }

  .translation__stamp {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: #8ea1ad;
    margin: 16px 0 0;
  }
</style>
