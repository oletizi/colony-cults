---
/**
 * T017 / T019b -- the SOURCE OVERVIEW route (one per source). `getStaticPaths`
 * loads the corpus and enumerates every source, emitting `{ sourceId }` with
 * the source's issue ledger (date-ordered) as props. Each issue row links into
 * the reading view at that issue's FIRST page -- the deep-linkable entry point
 * the reading-view route (`.../pages/[pageId].astro`) also emits.
 *
 * The dossier's contents page: the source speaks its title in the warm Didone
 * voice; the apparatus (counts, dates, ids, the issue ledger) is the cool
 * monospace voice. Not-collected issues are surfaced as a quiet archival
 * footnote (honours "no silent caps") -- never fabricated.
 *
 * Fail-loud by construction: `loadCorpus` throws on any incomplete/corrupt
 * page, and an issue that resolved to zero pages throws here rather than
 * emitting a ledger row that links nowhere.
 */
import type { GetStaticPaths } from 'astro';
import { loadCorpus } from '@/browser/load/corpus';
import { resolveConfig } from '@/browser/config';
import BaseLayout from '@site/layouts/BaseLayout.astro';

export const getStaticPaths = (() => {
  // Defined inside getStaticPaths: Astro evaluates this export in isolation, so
  // module-scope helpers are not in scope here.
  const pageHref = (sourceId: string, issueId: string, pageId: string): string =>
    `/sources/${sourceId}/issues/${issueId}/pages/${pageId}/`;

  const { corpus, skipped } = loadCorpus(resolveConfig());

  return corpus.sources.map((source) => {
    const issues = source.issues.map((issue) => {
      const firstPage = issue.pages[0];
      if (firstPage === undefined) {
        // A loaded issue always carries pages (loadCorpus skips/throws
        // otherwise); guard so we never emit a row that links to no page.
        throw new Error(
          `source overview(${source.sourceId}): issue ${issue.issueId} has no pages ` +
            '-- cannot link the ledger row to a reading-view route.'
        );
      }
      return {
        issueId: issue.issueId,
        date: issue.date,
        sequence: issue.sequence,
        pageCount: issue.pageCount,
        firstPageHref: pageHref(source.sourceId, issue.issueId, firstPage.pageId),
      };
    });

    const skippedCount = skipped.filter((s) => s.sourceId === source.sourceId).length;

    return {
      params: { sourceId: source.sourceId },
      props: {
        sourceId: source.sourceId,
        title: source.title,
        kind: source.kind,
        ark: source.ark,
        rights: source.rights,
        issues,
        skippedCount,
      },
    };
  });
}) satisfies GetStaticPaths;

interface IssueRow {
  issueId: string;
  date: string;
  sequence: number;
  pageCount: number;
  firstPageHref: string;
}

interface Props {
  sourceId: string;
  title: string;
  kind: string;
  ark: string;
  rights: string;
  issues: IssueRow[];
  skippedCount: number;
}

const { sourceId, title, kind, ark, rights, issues, skippedCount } = Astro.props;

const kindLabel = kind.charAt(0).toUpperCase() + kind.slice(1);
const issueCount = issues.length;
const issueNoun = issueCount === 1 ? 'issue' : 'issues';

const years = issues.map((i) => i.date.slice(0, 4));
const firstYear = years[0];
const lastYear = years[years.length - 1];
const yearRange =
  firstYear === undefined ? '' : firstYear === lastYear ? firstYear : `${firstYear}–${lastYear}`;

const skippedNoun = skippedCount === 1 ? 'issue' : 'issues';
const docTitle = `${title} · ${sourceId}`;
---

<BaseLayout title={docTitle} description={`Issue ledger for ${title} (${sourceId}) — ${issueCount} ${issueNoun}.`}>
  <article class="ledger" aria-label={`Source overview — ${title}`}>
    <header class="ledger__masthead">
      <p class="ledger__eyebrow">
        <a class="ledger__home" href="/">Corpus</a>
        <span class="ledger__sep">·</span>
        {sourceId}
      </p>
      <h1 class="ledger__title">{title}</h1>
      <p class="ledger__sub">
        {kindLabel}
        <span class="ledger__sep">·</span>
        {issueCount} {issueNoun}
        {yearRange ? <><span class="ledger__sep">·</span>{yearRange}</> : null}
      </p>
    </header>

    <div class="ledger__frame">
      <div class="ledger__chrome">
        <span>Issues<span class="ledger__sep">·</span>chronological</span>
        <span class="ledger__spacer"></span>
        <span>{issueCount} {issueNoun}</span>
      </div>

      {issues.length > 0 ? (
        <ol class="ledger__list">
          {issues.map((issue) => (
            <li class="ledger__item">
              <a class="issue" href={issue.firstPageHref}>
                <span class="issue__date">{issue.date}</span>
                <span class="issue__meta">{issue.pageCount} {issue.pageCount === 1 ? 'page' : 'pages'}</span>
                <span class="issue__go">Read<span class="issue__chev" aria-hidden="true">›</span></span>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="ledger__empty">No issues are collected for this source yet.</p>
      )}

      <div class="ledger__foot">
        <span class="ledger__prov">{sourceId}<span class="ledger__sep">·</span>{ark}<span class="ledger__sep">·</span><span class="ledger__rights">{rights}</span></span>
        <span class="ledger__spacer"></span>
        {skippedCount > 0 ? (
          <span class="ledger__note" role="note">
            {skippedCount} {skippedNoun} in this holding not yet collected
          </span>
        ) : null}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .ledger {
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 28px 96px;
  }

  .ledger__masthead {
    margin-bottom: 26px;
  }

  .ledger__eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--oxide);
    margin: 0 0 12px;
  }

  .ledger__home {
    color: var(--oxide);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }

  .ledger__home:hover {
    border-bottom-color: var(--oxide);
  }

  .ledger__title {
    font-family: var(--didone);
    font-weight: 400;
    font-size: clamp(30px, 6vw, 54px);
    line-height: 1.02;
    letter-spacing: -0.01em;
    margin: 0 0 10px;
  }

  .ledger__sub {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.05em;
    color: var(--faint);
    margin: 0;
  }

  .ledger__sep {
    color: var(--rule);
    margin: 0 7px;
  }

  .ledger__frame {
    border: 1px solid var(--rule);
    background: #fff;
    box-shadow: 0 1px 0 var(--rule), 0 22px 44px -30px rgba(23, 21, 15, 0.45);
  }

  .ledger__chrome {
    display: flex;
    align-items: center;
    padding: 11px 18px;
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .ledger__spacer {
    flex: 1;
  }

  .ledger__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ledger__item + .ledger__item .issue {
    border-top: 1px solid var(--rule);
  }

  .issue {
    display: flex;
    align-items: baseline;
    gap: 18px;
    padding: 15px 18px;
    text-decoration: none;
    color: var(--ink);
  }

  .issue:hover {
    background: var(--vellum);
  }

  .issue__date {
    font-family: var(--mono);
    font-size: 15px;
    letter-spacing: 0.04em;
    color: var(--ink);
    min-width: 8.5em;
  }

  .issue__meta {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--faint);
  }

  .issue__go {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--slate);
    white-space: nowrap;
  }

  .issue__chev {
    margin-left: 7px;
    color: var(--rule);
    font-size: 13px;
  }

  .issue:hover .issue__go {
    color: var(--oxide);
  }

  .issue:hover .issue__chev {
    color: var(--oxide);
  }

  .ledger__empty {
    font-family: var(--grote);
    font-size: 14px;
    font-style: italic;
    color: var(--faint);
    padding: 22px 18px;
    margin: 0;
  }

  .ledger__foot {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 10px 14px;
    padding: 12px 18px;
    border-top: 1px solid var(--rule);
    background: var(--paper);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--faint);
  }

  .ledger__prov {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
  }

  .ledger__rights {
    color: var(--oxide);
  }

  .ledger__note {
    color: var(--slate);
  }

  @media (max-width: 640px) {
    .issue {
      flex-wrap: wrap;
      gap: 6px 14px;
    }

    .issue__date {
      min-width: 0;
      flex-basis: 100%;
    }

    .ledger__prov {
      white-space: normal;
      flex-basis: 100%;
    }
  }
</style>
